---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Karriere - E-Kinderauto">
	<Header />
	<main class="bg-white pb-20">
		<div class="bg-gray-50 py-12 md:py-20 mb-12 border-b border-gray-100">
			<div class="container mx-auto px-6 md:px-12 text-center">
				<h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Karriere</h1>
				<p class="text-gray-500 max-w-2xl mx-auto text-lg">
					Werde Teil unseres Teams und gestalte den Shop mit uns weiter.
				</p>
			</div>
		</div>

		<div class="container mx-auto px-6 md:px-12 max-w-3xl">
			<div class="prose prose-gray max-w-none">
				<p>
					Aktuell sind keine konkreten Stellen ausgeschrieben.
				</p>
			</div>
		</div>
	</main>
</Layout>
