---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Impressum - E-Kinderauto">
	<Header />
	<main class="bg-white pb-20">
		<div class="bg-gray-50 py-12 md:py-20 mb-12 border-b border-gray-100">
			<div class="container mx-auto px-6 md:px-12 text-center">
				<h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Impressum</h1>
				<p class="text-gray-500 max-w-2xl mx-auto text-lg">
					Anbieterkennzeichnung gemaess 5 TMG.
				</p>
			</div>
		</div>

		<div class="container mx-auto px-6 md:px-12 max-w-3xl">
			<div class="space-y-6">
				<section class="bg-white border border-gray-100 rounded-xl p-6 md:p-8">
					<h2 class="text-2xl font-semibold tracking-tight text-gray-900 mb-4 pb-2 border-b border-gray-100">
						Angaben gemaess 5 TMG
					</h2>
					<p class="text-gray-700 leading-relaxed">
						E-Kinderauto<br />
						Einzelgewerbe<br />
						Schlossplatz 1<br />
						67292 Kirchheimbolanden<br />
						Deutschland
					</p>
				</section>

				<section class="bg-white border border-gray-100 rounded-xl p-6 md:p-8">
					<h2 class="text-2xl font-semibold tracking-tight text-gray-900 mb-4 pb-2 border-b border-gray-100">
						Vertreten durch
					</h2>
					<p class="text-gray-700 leading-relaxed">Jason Lohre</p>
				</section>

				<section class="bg-white border border-gray-100 rounded-xl p-6 md:p-8">
					<h2 class="text-2xl font-semibold tracking-tight text-gray-900 mb-4 pb-2 border-b border-gray-100">
						Kontakt
					</h2>
					<p class="text-gray-700 leading-relaxed">
						Telefon: <a href="tel:+4915147918371" class="text-black hover:underline">0151 47918371</a><br />
						E-Mail:
						<a href="mailto:info@e-kinderauto.de" class="text-black hover:underline">info@e-kinderauto.de</a>
					</p>
				</section>

				<section class="bg-white border border-gray-100 rounded-xl p-6 md:p-8">
					<h2 class="text-2xl font-semibold tracking-tight text-gray-900 mb-4 pb-2 border-b border-gray-100">
						Registereintrag
					</h2>
					<p class="text-gray-700 leading-relaxed">Nicht im Handelsregister eingetragen.</p>
				</section>

				<section class="bg-white border border-gray-100 rounded-xl p-6 md:p-8">
					<h2 class="text-2xl font-semibold tracking-tight text-gray-900 mb-4 pb-2 border-b border-gray-100">
						Umsatzsteuer-ID
					</h2>
					<p class="text-gray-700 leading-relaxed">Keine Umsatzsteuer-Identifikationsnummer vorhanden.</p>
				</section>
			</div>
		</div>
	</main>
</Layout>
