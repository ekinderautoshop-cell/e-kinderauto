---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Impressum - E-Kinderauto">
	<Header />
	<main class="bg-white pb-20">
		<div class="bg-gray-50 py-12 md:py-20 mb-12 border-b border-gray-100">
			<div class="container mx-auto px-6 md:px-12 text-center">
				<h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Impressum</h1>
				<p class="text-gray-500 max-w-2xl mx-auto text-lg">
					Anbieterkennzeichnung gemaess 5 TMG.
				</p>
			</div>
		</div>

		<div class="container mx-auto px-6 md:px-12 max-w-3xl">
			<div class="prose prose-gray max-w-none">
				<h2>Angaben gemaess 5 TMG</h2>
				<p>
					E-Kinderauto<br />
					Einzelgewerbe<br />
					Schlossplatz 1<br />
					67292 Kirchheimbolanden<br />
					Deutschland
				</p>

				<h2>Vertreten durch</h2>
				<p>Jason Lohre</p>

				<h2>Kontakt</h2>
				<p>
					Telefon: 0151 47918371<br />
					E-Mail: info@e-kinderauto.de
				</p>

				<h2>Registereintrag</h2>
				<p>
					Nicht im Handelsregister eingetragen.
				</p>

				<h2>Umsatzsteuer-ID</h2>
				<p>Keine Umsatzsteuer-Identifikationsnummer vorhanden.</p>
			</div>
		</div>
	</main>
</Layout>
