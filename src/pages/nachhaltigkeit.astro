---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Nachhaltigkeit - E-Kinderauto">
	<Header />
	<main class="bg-white pb-20">
		<div class="bg-gray-50 py-12 md:py-20 mb-12 border-b border-gray-100">
			<div class="container mx-auto px-6 md:px-12 text-center">
				<h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Nachhaltigkeit</h1>
				<p class="text-gray-500 max-w-2xl mx-auto text-lg">
					Unser Beitrag zu langlebigen Produkten und verantwortungsvollem Handeln.
				</p>
			</div>
		</div>

		<div class="container mx-auto px-6 md:px-12 max-w-3xl">
			<div class="prose prose-gray max-w-none">
				<h2>Langlebigkeit statt Wegwerfprodukt</h2>
				<p>
					Wir setzen auf robuste Produkte und verfuegbare Ersatzteile, damit Fahrzeuge moeglichst lange genutzt
					werden koennen.
				</p>

				<h2>Reparaturfreundlichkeit</h2>
				<p>
					Durch Ersatz- und Zusatzartikel erleichtern wir Wartung und Reparatur, statt sofort neu zu kaufen.
				</p>

				<h2>Kontinuierliche Verbesserung</h2>
				<p>
					Wir arbeiten laufend daran, Verpackung, Logistik und Produktqualitaet weiter zu optimieren.
				</p>
			</div>
		</div>
	</main>
</Layout>
